# =============================================================
# PhysioConnect Environment Variables
# =============================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# =============================================================

# --- Database (Required) ---
# PostgreSQL connection string used by Prisma ORM at runtime (pooled)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DATABASE?pgbouncer=true"

# Direct connection to PostgreSQL (bypasses PgBouncer) — used by Prisma CLI
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# --- Authentication (Required) ---
# Secret key for signing JWT tokens — use a random 64+ char string
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=""

# --- Razorpay Payment Gateway (Required for payments) ---
# Get keys from: https://dashboard.razorpay.com/app/keys
# Use TEST keys during development (prefix: rzp_test_)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# --- Razorpay Public Key (Required for frontend checkout) ---
# Same value as RAZORPAY_KEY_ID — exposed to the browser
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# --- Google Maps (Optional) ---
# If missing, clinics page shows static fallback — app will NOT crash
# Get key from: https://console.cloud.google.com/google/maps-apis
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# --- Demo Mode (Optional) ---
# Set to "true" to serve sample/fallback data instead of hitting the database
# Useful for showcasing the app without a live database
# DEMO_MODE=true
